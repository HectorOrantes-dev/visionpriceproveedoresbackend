# ===========================================
# VisionPrice Proveedores Backend — Environment
# ===========================================

# Server
SERVER_PORT=8080

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
SUPABASE_KEY=[YOUR_SUPABASE_ANON_KEY]

# JWT — Use a strong secret of at least 32 characters (e.g., openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_MINUTES=15
REFRESH_TOKEN_EXPIRATION_HOURS=168

# 2FA / OTP
OTP_EXPIRATION_MINUTES=5

# Email para OTP/2FA. Prioridad: Gmail API > Brevo > log (dev).
# Ambos proveedores usan HTTPS (443), así que funcionan donde SMTP está bloqueado (Railway).
#
# Gmail API (RECOMENDADO: mejor entregabilidad, gratis, sin dominio).
# Envía desde tu Gmail real vía OAuth2. Si GMAIL_REFRESH_TOKEN está seteado, se usa Gmail.
# Cómo obtener las credenciales (setup único):
#   1. console.cloud.google.com → crea un proyecto.
#   2. "APIs y servicios" → habilita "Gmail API".
#   3. "Pantalla de consentimiento OAuth" (External) → agrega tu Gmail como usuario de prueba.
#   4. "Credenciales" → crea "ID de cliente OAuth" tipo "App de escritorio" → copia client_id y client_secret.
#   5. En OAuth Playground (developers.google.com/oauthplayground): engrana → "Use your own credentials"
#      → scope https://www.googleapis.com/auth/gmail.send → Authorize → Exchange → copia el refresh_token.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM=tucorreo@gmail.com
GMAIL_FROM_NAME=VisionPrice

# Brevo: alternativa sin dominio (verifica un remitente). Puede caer en spam.
# Si no hay ningún proveedor configurado, el OTP se loguea en consola (dev).
BREVO_API_KEY=
BREVO_FROM_EMAIL=tucorreo@gmail.com
BREVO_FROM_NAME=VisionPrice

# Password Reset
PASSWORD_RESET_EXPIRATION_MINUTES=15

# CORS — Comma-separated list of allowed origins. NEVER use '*' in production.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4200

# Swagger — Set to true only in development/staging
ENABLE_SWAGGER=true

# Microservicio catálogo (auth servicio-a-servicio con header X-Api-Key).
# Debe coincidir con el PROVIDERS_API_KEY que use el gateway que lo consume.
# Si está vacía, los endpoints /productos* rechazan todo con 401.
MICROSERVICE_API_KEY=

# ===========================================
# Payments / Billing (B2B subscriptions)
# Leave PAYMENTS_ENABLED=false until real credentials are configured.
# ===========================================
PAYMENTS_ENABLED=false
PAYMENT_DEFAULT_GATEWAY=conekta
SUBSCRIPTION_SUCCESS_URL=https://visionprice.app/billing/success
SUBSCRIPTION_CANCEL_URL=https://visionprice.app/billing/cancel

# Conekta
CONEKTA_PRIVATE_KEY=
CONEKTA_WEBHOOK_SECRET=
# IDs de los planes creados en el panel de Conekta (Referencia / ID interno)
CONEKTA_PLAN_PRO=planes-proveedores-pro
CONEKTA_PLAN_MAX=planes-proveedores-max

# PayPal (sandbox | live)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox
# IDs de los billing plans creados en PayPal (formato P-XXXXXXXX)
PAYPAL_PLAN_PRO=
PAYPAL_PLAN_MAX=
