# ===========================================
# VisionPrice Proveedores Backend — Environment
# ===========================================

# Server
SERVER_PORT=8080

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
SUPABASE_KEY=[YOUR_SUPABASE_ANON_KEY]

# JWT — Use a strong secret of at least 32 characters (e.g., openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_MINUTES=15
REFRESH_TOKEN_EXPIRATION_HOURS=168

# 2FA / OTP
OTP_EXPIRATION_MINUTES=5

# Email para OTP/2FA. Selección por prioridad: Resend > SMTP > log (dev).
#
# Resend (RECOMENDADO en Railway/PaaS): envía por HTTPS (443), no se bloquea como SMTP.
# Si RESEND_API_KEY está seteada, se usa Resend y se ignora el SMTP de abajo.
RESEND_API_KEY=
# Remitente. Usa el dominio de pruebas de Resend o uno verificado en tu cuenta.
RESEND_FROM=VisionPrice <onboarding@resend.dev>

# SMTP — alternativa solo si NO usas Resend y tu plataforma permite SMTP saliente.
# OJO: Railway y la mayoría de PaaS BLOQUEAN los puertos SMTP (25/465/587).
# Si SMTP_HOST y RESEND_API_KEY están vacíos, el OTP se loguea en consola (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@visionprice.app
SMTP_FROM_NAME=VisionPrice

# Password Reset
PASSWORD_RESET_EXPIRATION_MINUTES=15

# CORS — Comma-separated list of allowed origins. NEVER use '*' in production.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Swagger — Set to true only in development/staging
ENABLE_SWAGGER=true

# ===========================================
# Payments / Billing (B2B subscriptions)
# Leave PAYMENTS_ENABLED=false until real credentials are configured.
# ===========================================
PAYMENTS_ENABLED=false
PAYMENT_DEFAULT_GATEWAY=conekta
SUBSCRIPTION_SUCCESS_URL=https://visionprice.app/billing/success
SUBSCRIPTION_CANCEL_URL=https://visionprice.app/billing/cancel

# Conekta
CONEKTA_PRIVATE_KEY=
CONEKTA_WEBHOOK_SECRET=
# IDs de los planes creados en el panel de Conekta (Referencia / ID interno)
CONEKTA_PLAN_PRO=planes-proveedores-pro
CONEKTA_PLAN_MAX=planes-proveedores-max

# PayPal (sandbox | live)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox
# IDs de los billing plans creados en PayPal (formato P-XXXXXXXX)
PAYPAL_PLAN_PRO=
PAYPAL_PLAN_MAX=
